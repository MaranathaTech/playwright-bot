{
  "name": "@playwright-bot/core",
  "version": "0.1.0",
  "description": "AI-powered Playwright test generation engine",
  "author": "Marantha Tech <https://github.com/MaranathaTech>",
  "homepage": "https://github.com/MaranathaTech/playwright-bot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaranathaTech/playwright-bot.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/MaranathaTech/playwright-bot/issues"
  },
  "keywords": [
    "playwright",
    "testing",
    "test-generation",
    "ai",
    "automation",
    "e2e",
    "end-to-end"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "playwright-core": ">=1.50.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "sharp": "^0.33.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "playwright-core": "^1.50.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
