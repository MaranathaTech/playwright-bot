{
  "name": "@playwright-ai-bot/react-panel",
  "version": "0.1.1",
  "description": "React dev panel for playwright-bot",
  "author": "Marantha Tech <https://github.com/MaranathaTech>",
  "homepage": "https://github.com/MaranathaTech/playwright-bot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaranathaTech/playwright-bot.git",
    "directory": "packages/react-panel"
  },
  "bugs": {
    "url": "https://github.com/MaranathaTech/playwright-bot/issues"
  },
  "keywords": [
    "playwright",
    "testing",
    "react",
    "devtools",
    "panel",
    "ai",
    "automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "react-force-graph-2d": "^1.25.0",
    "@codemirror/lang-javascript": "^6.2.0",
    "codemirror": "^6.0.0",
    "@uiw/react-codemirror": "^4.23.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
