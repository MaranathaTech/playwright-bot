{
  "name": "playwright-bot",
  "version": "0.1.0",
  "description": "AI-powered Playwright test generator CLI",
  "author": "Marantha Tech <https://github.com/MaranathaTech>",
  "homepage": "https://github.com/MaranathaTech/playwright-bot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaranathaTech/playwright-bot.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/MaranathaTech/playwright-bot/issues"
  },
  "keywords": [
    "playwright",
    "testing",
    "test-generation",
    "ai",
    "automation",
    "e2e",
    "end-to-end",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "bin": {
    "playwright-bot": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@playwright-ai-bot/core": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "jiti": "^2.4.0",
    "ora": "^8.1.0",
    "playwright-core": "^1.50.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/ws": "^8.5.0"
  },
  "license": "MIT"
}
